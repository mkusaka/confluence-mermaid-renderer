{
  "name": "confluence-mermaid-renderer",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "vite build",
    "check": "pnpm format:check && pnpm lint:ci && pnpm typecheck && pnpm build",
    "dev": "vite build --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "icons:generate": "node scripts/generate-icons.mjs",
    "lint": "oxlint . --import-plugin --tsconfig ./tsconfig.json",
    "lint:ci": "oxlint . --import-plugin --tsconfig ./tsconfig.json --deny-warnings",
    "lint:fix": "oxlint . --import-plugin --tsconfig ./tsconfig.json --fix",
    "package": "pnpm build && cd dist && zip -r -FS ../package.zip .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mermaid": "11.15.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@types/node": "25.9.1",
    "oxlint": "1.68.0",
    "prettier": "3.8.3",
    "terser": "5.48.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
