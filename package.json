{
  "name": "confluence-mermaid-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "vite build",
    "check": "pnpm format:check && pnpm lint:ci && pnpm typecheck && pnpm build",
    "dev": "vite build --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint . --import-plugin --tsconfig ./tsconfig.json",
    "lint:ci": "oxlint . --import-plugin --tsconfig ./tsconfig.json --deny-warnings",
    "lint:fix": "oxlint . --import-plugin --tsconfig ./tsconfig.json --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mermaid": "11.15.0"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "oxlint": "1.64.0",
    "prettier": "3.8.3",
    "terser": "5.47.1",
    "typescript": "6.0.3",
    "vite": "8.0.13"
  }
}
